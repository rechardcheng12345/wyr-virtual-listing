{
  "name": "virtual-listing",
  "version": "1.0.0",
  "description": "Virtual Listing - Product management with file delivery",
  "main": "backend/src/index.ts",
  "scripts": {
    "start": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "tsx watch backend/src/index.ts",
    "server:start": "tsx backend/src/index.ts",
    "client:dev": "cd frontend && npm run dev",
    "client:build": "cd frontend && npm install && npm run build",
    "install-all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "nodemailer": "^6.9.13",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.4.5"
  }
}
